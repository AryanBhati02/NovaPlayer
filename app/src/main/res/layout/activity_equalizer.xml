<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <com.google.android.material.button.MaterialButton android:id="@+id/btnEqBack"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="← Equalizer" android:textColor="@color/accent_cyan"
            android:textSize="16sp" android:layout_marginBottom="8dp"
            android:layout_marginTop="40dp"/>

        <TextView android:text="Preset" android:textColor="@color/text_secondary"
            android:textSize="12sp" android:letterSpacing="0.1"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"/>

        <Spinner android:id="@+id/spinnerPresets"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/chip_bg" android:paddingHorizontal="12dp"/>

        <TextView android:text="BANDS" android:textColor="@color/text_secondary"
            android:textSize="11sp" android:letterSpacing="0.2"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="20dp" android:layout_marginBottom="8dp"/>

        <LinearLayout android:id="@+id/llEqBands"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginVertical="20dp"/>

        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchBassBoost"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Bass Boost" android:textColor="@color/text_primary" android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchVirtualizer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="3D Virtualizer" android:textColor="@color/text_primary" android:textSize="15sp"/>
    </LinearLayout>
</ScrollView>
