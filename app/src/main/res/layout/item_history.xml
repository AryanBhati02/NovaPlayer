<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="72dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingHorizontal="16dp" android:background="?attr/selectableItemBackground">

    <androidx.cardview.widget.CardView
        android:layout_width="52dp" android:layout_height="52dp"
        app:cardCornerRadius="12dp" app:cardBackgroundColor="#1A9B5CF6"
        android:layout_marginEnd="14dp">
        <ImageView android:layout_width="24dp" android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_lyrics" android:tint="@color/accent_purple"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvHistoryName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"
            android:singleLine="true" android:ellipsize="end"/>
        <TextView android:id="@+id/tvHistoryMeta"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="12sp"
            android:layout_marginTop="2dp" android:text="Tap to play"/>
    </LinearLayout>

    <ImageView android:layout_width="20dp" android:layout_height="20dp"
        android:src="@drawable/ic_play" android:tint="@color/text_secondary"/>
</LinearLayout>
