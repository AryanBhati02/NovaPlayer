<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- ── TOP BAR ─────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:text="MediaPlayer"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-condensed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Audio &amp; Video"
            android:textSize="13sp"
            android:textColor="@color/accent_cyan"
            android:letterSpacing="0.12"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- ── DIVIDER ────────────────────────────────────────────── -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── MEDIA DISPLAY CARD ─────────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMedia"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardElevation="12dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardControls"
        app:layout_constraintVertical_bias="0.0">

        <!-- Media3 PlayerView (visible when streaming direct links) -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:use_controller="false"
            app:resize_mode="fit" />

        <!-- YouTube PlayerView (visible when streaming YouTube links) -->
        <com.pierfrancescosoffritti.androidyoutubeplayer.core.player.views.YouTubePlayerView
            android:id="@+id/youtubePlayerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:enableAutomaticInitialization="false" />

        <!-- Audio visualization (visible when playing audio) -->
        <LinearLayout
            android:id="@+id/layoutAudioViz"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/bg_card"
            android:padding="24dp">

            <!-- Waveform bars -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <View android:id="@+id/bar1"
                    style="@style/WaveBar"
                    android:layout_marginEnd="5dp" />
                <View android:id="@+id/bar2"
                    style="@style/WaveBar"
                    android:layout_marginEnd="5dp" />
                <View android:id="@+id/bar3"
                    style="@style/WaveBar"
                    android:layout_marginEnd="5dp" />
                <View android:id="@+id/bar4"
                    style="@style/WaveBar"
                    android:layout_marginEnd="5dp" />
                <View android:id="@+id/bar5"
                    style="@style/WaveBar"
                    android:layout_marginEnd="5dp" />
                <View android:id="@+id/bar6"
                    style="@style/WaveBar"
                    android:layout_marginEnd="5dp" />
                <View android:id="@+id/bar7"
                    style="@style/WaveBar" />

            </LinearLayout>

            <!-- Media title -->
            <TextView
                android:id="@+id/tvMediaTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No media loaded"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Status text -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open a file or enter a URL to begin"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Loading spinner overlay -->
        <ProgressBar
            android:id="@+id/progressLoading"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/accent_cyan"
            android:visibility="gone" />

    </androidx.cardview.widget.CardView>

    <!-- ── CONTROLS CARD ──────────────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- SeekBar row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="start" />

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progressTint="@color/accent_cyan"
                    android:thumbTint="@color/accent_cyan"
                    android:progressBackgroundTint="@color/divider"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:gravity="end" />

            </LinearLayout>

            <!-- Playback controls: Play/Pause, Stop, Restart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp">

                <!-- Restart -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRestart"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="RESTART"
                    android:textSize="10sp"
                    android:textColor="@color/accent_cyan"
                    app:icon="@drawable/ic_restart"
                    app:iconTint="@color/accent_cyan"
                    app:iconSize="14dp"
                    app:iconPadding="4dp"
                    app:iconGravity="textStart"
                    app:strokeColor="@color/accent_cyan"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    android:layout_marginEnd="4dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp" />

                <!-- Play / Pause -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlayPause"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1.4"
                    android:text="PLAY"
                    android:textSize="13sp"
                    android:textColor="@color/bg_dark"
                    app:icon="@drawable/ic_play"
                    app:iconTint="@color/bg_dark"
                    app:iconSize="20dp"
                    app:iconPadding="6dp"
                    app:iconGravity="textStart"
                    app:backgroundTint="@color/accent_cyan"
                    app:cornerRadius="16dp"
                    android:layout_marginHorizontal="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <!-- Stop -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="STOP"
                    android:textSize="10sp"
                    android:textColor="@color/accent_red"
                    app:icon="@drawable/ic_stop"
                    app:iconTint="@color/accent_red"
                    app:iconSize="14dp"
                    app:iconPadding="4dp"
                    app:iconGravity="textStart"
                    app:strokeColor="@color/accent_red"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    android:layout_marginStart="4dp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp" />

            </LinearLayout>

            <!-- ── SOURCE BUTTONS ─────────────────────────────── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Open File -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenFile"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Open File"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    app:icon="@drawable/ic_folder"
                    app:iconTint="@color/text_primary"
                    app:iconSize="18dp"
                    app:iconPadding="4dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    android:layout_marginEnd="8dp" />

                <!-- Open URL -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenUrl"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Open URL"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    app:icon="@drawable/ic_link"
                    app:iconTint="@color/text_primary"
                    app:iconSize="18dp"
                    app:iconPadding="4dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
