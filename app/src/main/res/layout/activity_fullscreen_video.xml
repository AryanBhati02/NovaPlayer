<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView android:id="@+id/fsPlayerView"
        android:layout_width="match_parent" android:layout_height="match_parent"
        app:use_controller="true" app:resize_mode="fit"
        app:show_timeout="3000"/>

    <ImageButton android:id="@+id/btnExitFullscreen"
        android:layout_width="48dp" android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:src="@drawable/ic_fullscreen_exit"
        android:tint="#FFFFFFFF"
        android:background="#66000000"
        android:contentDescription="Exit fullscreen"/>

</FrameLayout>
